{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter market-write-node build",
    "watchPatterns": ["apps/market-write-node/**"]
  },
  "deploy": {
    "startCommand": "pnpm --filter market-write-node start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
